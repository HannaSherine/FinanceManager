<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New entry"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Transaction"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Amount Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AMOUNT"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="₹ 0.00"
                    android:inputType="numberDecimal"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:textColorHint="#CCCCCC"
                    android:background="#FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:letterSpacing="-0.02"/>
            </LinearLayout>

            <!-- Type Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TYPE"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnIncome"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="↑  Income"
                        android:textSize="14sp"
                        android:textColor="#065F46"
                        android:backgroundTint="#D1FAE5"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    <Button
                        android:id="@+id/btnExpense"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="↓  Expense"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:backgroundTint="#F0F0F0"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Category Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CATEGORY"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="8dp"/>

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/catFood"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍽️" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Food" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/catTravel"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚌" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Travel" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/catShopping"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛍️" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shopping" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/catHealth"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💊" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Health" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/catSalary"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Salary" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/catEducation"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎓" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Education" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/catRent"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rent" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/catUtilities"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Utilities" android:textSize="11sp" android:textColor="#555555" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Description -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCRIPTION"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What was this for?"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:textColorHint="#BBBBBB"
                    android:background="#FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"/>
            </LinearLayout>

            <!-- Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATE"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select date"
                    android:inputType="date"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:textColorHint="#BBBBBB"
                    android:background="#FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:focusable="false"
                    android:clickable="true"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Save Button pinned at bottom -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="Save Transaction"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A1A2E"
        style="@style/Widget.MaterialComponents.Button"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>